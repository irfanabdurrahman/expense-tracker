rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Family: readable/writable by members only
    match /families/{familyId} {
      allow read: if request.auth != null && isFamilyMember(familyId);
      allow create: if request.auth != null;
      allow update: if request.auth != null && isFamilyMember(familyId);
      allow delete: if request.auth != null && isFamilyAdmin(familyId);

      // Transactions inside a family
      match /transactions/{txnId} {
        allow read, write: if request.auth != null && isFamilyMember(familyId);
        allow delete: if request.auth != null && (
          isFamilyAdmin(familyId) ||
          resource.data.uid == request.auth.uid
        );
      }
    }

    // Invitations: anyone authenticated can read their own invite
    match /invitations/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if request.auth != null;
      allow delete: if request.auth != null && request.auth.token.email == email;
    }

    function isFamilyMember(familyId) {
      let family = get(/databases/$(database)/documents/families/$(familyId));
      let members = family.data.members;
      return members != null && members.hasAny([{
        'uid': request.auth.uid,
        'name': request.auth.token.name,
        'email': request.auth.token.email,
        'role': 'admin'
      }]) || members.hasAny([{
        'uid': request.auth.uid,
        'name': request.auth.token.name,
        'email': request.auth.token.email,
        'role': 'member'
      }]);
    }

    function isFamilyAdmin(familyId) {
      let family = get(/databases/$(database)/documents/families/$(familyId));
      return family.data.adminUid == request.auth.uid;
    }
  }
}
